{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "includeFiles": [
    "BPS_Inflasi_WideFormat_Datetime.xlsx",
    "PIHPS_Provinsi_WideFormat.csv",
    "Data/**"
  ]
}
