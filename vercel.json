{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/BPS_Inflasi_WideFormat_Datetime.xlsx",
      "dest": "/BPS_Inflasi_WideFormat_Datetime.xlsx"
    },
    {
      "src": "/PIHPS_Provinsi_WideFormat.csv",
      "dest": "/PIHPS_Provinsi_WideFormat.csv"
    },
    {
      "src": "/Data/(.*)",
      "dest": "/Data/$1"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
